{
  "name": "@apps/vue-web",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "vite",
    "dev:local": "vite --mode development",
    "dev:test": "vite --mode test",
    "dev:uat": "vite --mode uat",
    "build": "vue-tsc -b && vite build",
    "build:local": "vue-tsc -b && vite build --mode development",
    "build:test": "vue-tsc -b && vite build --mode test",
    "build:uat": "vue-tsc -b && vite build --mode uat",
    "analyze": "vue-tsc -b && cross-env BUILD_ANALYZE=true vite build",
    "lint": "eslint .",
    "typecheck": "vue-tsc -b",
    "test": "vitest run --passWithNoTests",
    "test:coverage": "vitest run --coverage",
    "test:e2e": "playwright test --project=chromium",
    "test:e2e:all": "playwright test",
    "test:e2e:ui": "playwright test --ui --project=chromium",
    "test:e2e:headed": "playwright test --headed --project=chromium",
    "test:e2e:report": "playwright show-report ../../reports/playwright/vue-web/html",
    "version:patch": "node ../../scripts/update-app-version.mjs --bump patch",
    "version:minor": "node ../../scripts/update-app-version.mjs --bump minor",
    "version:major": "node ../../scripts/update-app-version.mjs --bump major",
    "version:set": "node ../../scripts/update-app-version.mjs --set",
    "clean": "rimraf dist"
  },
  "dependencies": {
    "@repo/config": "workspace:*",
    "@repo/observability": "workspace:*",
    "@repo/request": "workspace:*",
    "@repo/utils": "workspace:*",
    "@repo/vue-ui": "workspace:*",
    "@vueuse/core": "catalog:",
    "lodash": "catalog:",
    "pinia": "catalog:",
    "vue": "catalog:",
    "vue-router": "catalog:"
  },
  "devDependencies": {
    "@playwright/test": "catalog:",
    "@repo/playwright-config": "workspace:*",
    "@repo/tsconfig": "workspace:*",
    "@tailwindcss/vite": "catalog:",
    "@testing-library/jest-dom": "catalog:",
    "@testing-library/vue": "catalog:",
    "@types/lodash": "catalog:",
    "@vitejs/plugin-vue": "catalog:",
    "cross-env": "catalog:",
    "happy-dom": "catalog:",
    "rollup-plugin-visualizer": "catalog:",
    "sass-embedded": "catalog:",
    "tailwindcss": "catalog:",
    "vue-tsc": "catalog:"
  }
}
