# 环境配置模板
# 复制此文件为 .env 并填写实际值

# 应用
NODE_ENV=development
APP_PORT=3000
APP_NAME=nestjs-project

# 数据库 (MySQL)
DB_HOST=localhost
DB_PORT=3306
DB_USERNAME=root
DB_PASSWORD=
DB_DATABASE=nestjs_dev

# 数据库连接 URL (可选，设置后优先于散列变量)
# DATABASE_URL=mysql://root:password@localhost:3306/nestjs_dev

# JWT
JWT_SECRET=your-jwt-secret-at-least-16-chars
JWT_ACCESS_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=7d

# Redis
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=
REDIS_DB=0

# 滑块验证码 / 登录防护
CAPTCHA_ENABLED=true
CAPTCHA_REQUIRED_ALWAYS=false
CAPTCHA_SLIDER_TTL=120
CAPTCHA_TOKEN_TTL=300
CAPTCHA_SLIDER_TOLERANCE=5
CAPTCHA_MIN_DURATION=300
CAPTCHA_BIND_IP=false
LOGIN_FAIL_CAPTCHA_THRESHOLD_ACCOUNT=3
LOGIN_FAIL_CAPTCHA_THRESHOLD_IP=5
LOGIN_FAIL_TTL=900

# SMS verification code
SMS_CODE_TTL=300
SMS_CODE_RESEND_INTERVAL=60

# 雪花 ID
SNOWFLAKE_EPOCH=2025-01-01
SNOWFLAKE_MACHINE_ID=1

# 队列 (BullMQ 复用 Redis 连接配置，无需单独配置)
# 队列任务默认选项可在 src/infra/queue/queue.module.ts 中调整

# 日志 (debug | info | warn | error)
LOG_LEVEL=debug
