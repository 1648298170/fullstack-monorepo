# 开发环境配置
NODE_ENV=development
APP_PORT=3019
APP_NAME=nestjs-project

# 数据库 (MySQL)
DB_HOST=localhost
DB_PORT=3306
DB_USERNAME=root
DB_PASSWORD=root123456
DB_DATABASE=app_db

# 日志
LOG_LEVEL=debug

# JWT
JWT_SECRET=dev-secret-for-local-development
JWT_ACCESS_EXPIRES_IN=1h
JWT_REFRESH_EXPIRES_IN=30d

# Redis
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=redis123456
REDIS_DB=0

# 雪花 ID
SNOWFLAKE_EPOCH=2025-01-01
SNOWFLAKE_MACHINE_ID=1

# 队列 (BullMQ 复用上方 Redis 连接配置)
