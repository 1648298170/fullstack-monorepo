{
  "name": "@apps/api",
  "version": "0.1.0",
  "private": true,
  "type": "commonjs",
  "scripts": {
    "build": "nest build",
    "dev": "tsc-watch --noClear -p tsconfig.build.json --onSuccess \"node dist/main.js\"",
    "start": "node dist/main.js",
    "start:dev": "tsc-watch --noClear -p tsconfig.build.json --onSuccess \"node dist/main.js\"",
    "start:debug": "tsc-watch --noClear -p tsconfig.build.json --onSuccess \"node --inspect-brk dist/main.js\"",
    "start:prod": "node dist/main.js",
    "lint": "eslint .",
    "typecheck": "tsc -p tsconfig.build.json --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:cov": "vitest run --coverage",
    "test:e2e:api": "vitest run --config vitest.config.e2e.ts --passWithNoTests",
    "prisma:generate": "prisma generate",
    "prisma:migrate": "prisma migrate dev",
    "prisma:migrate:prod": "prisma migrate deploy",
    "prisma:studio": "prisma studio",
    "prisma:pull": "prisma db pull",
    "prisma:push": "prisma db push",
    "prisma:seed": "tsx prisma/seed.ts",
    "postinstall": "prisma generate",
    "clean": "rimraf dist"
  },
  "prisma": {
    "seed": "tsx prisma/seed.ts"
  },
  "dependencies": {
    "@nestjs/bullmq": "catalog:",
    "@nestjs/common": "catalog:",
    "@nestjs/config": "catalog:",
    "@nestjs/core": "catalog:",
    "@nestjs/jwt": "catalog:",
    "@nestjs/passport": "catalog:",
    "@nestjs/platform-express": "catalog:",
    "@nestjs/swagger": "catalog:",
    "@prisma/adapter-mariadb": "catalog:",
    "@prisma/client": "catalog:",
    "bcryptjs": "catalog:",
    "bullmq": "catalog:",
    "class-transformer": "catalog:",
    "class-validator": "catalog:",
    "dotenv": "catalog:",
    "express": "catalog:",
    "ioredis": "catalog:",
    "joi": "catalog:",
    "mariadb": "catalog:",
    "passport": "catalog:",
    "passport-jwt": "catalog:",
    "prisma": "catalog:",
    "reflect-metadata": "catalog:",
    "rxjs": "catalog:",
    "snowflake-id": "catalog:"
  },
  "devDependencies": {
    "@nestjs/cli": "catalog:",
    "@nestjs/schematics": "catalog:",
    "@nestjs/testing": "catalog:",
    "@repo/tsconfig": "workspace:*",
    "@types/express": "catalog:",
    "@types/node": "catalog:",
    "@types/passport-jwt": "catalog:",
    "@types/supertest": "catalog:",
    "@vitest/coverage-v8": "catalog:",
    "supertest": "catalog:",
    "tsc-watch": "catalog:",
    "tsx": "catalog:",
    "typescript": "catalog:",
    "vitest": "catalog:"
  }
}
