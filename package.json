{
  "name": "fullstack-monorepo",
  "version": "0.1.0",
  "description": "全栈 monorepo 模板，集成 Vue 3 / React 19 前端应用与 NestJS 11 后端应用，统一 pnpm workspace、Turborepo、TypeScript 6、ESLint、Prettier 与 Vitest 工程规范。",
  "private": true,
  "type": "module",
  "packageManager": "pnpm@10.18.3",
  "engines": {
    "node": ">=22.12.0",
    "pnpm": "10.18.3",
    "npm": ">=10.9.0 <11"
  },
  "scripts": {
    "preinstall": "node scripts/check-runtime-versions.mjs",
    "check:runtime": "node scripts/check-runtime-versions.mjs",
    "dev": "turbo dev",
    "dev:vue": "pnpm --filter @apps/vue-web dev",
    "dev:vue:local": "pnpm --filter @apps/vue-web dev:local",
    "dev:vue:test": "pnpm --filter @apps/vue-web dev:test",
    "dev:vue:uat": "pnpm --filter @apps/vue-web dev:uat",
    "dev:react": "pnpm --filter @apps/react-web dev",
    "dev:react:local": "pnpm --filter @apps/react-web dev:local",
    "dev:react:test": "pnpm --filter @apps/react-web dev:test",
    "dev:react:uat": "pnpm --filter @apps/react-web dev:uat",
    "build": "turbo build",
    "build:sourcemap": "cross-env BUILD_SOURCEMAP=true turbo build",
    "build:vue:local": "pnpm --filter @apps/vue-web build:local",
    "build:vue:test": "pnpm --filter @apps/vue-web build:test",
    "build:vue:uat": "pnpm --filter @apps/vue-web build:uat",
    "build:react:test": "pnpm --filter @apps/react-web build:test",
    "build:react:local": "pnpm --filter @apps/react-web build:local",
    "build:react:uat": "pnpm --filter @apps/react-web build:uat",
    "analyze:react": "pnpm --filter @apps/react-web analyze",
    "analyze:vue": "pnpm --filter @apps/vue-web analyze",
    "generate": "node scripts/generate.mjs",
    "g": "node scripts/generate.mjs",
    "version:app": "node scripts/update-app-version.mjs",
    "dev:app": "node scripts/run-app-command.mjs dev",
    "build:app": "node scripts/run-app-command.mjs build",
    "test:app": "node scripts/run-app-command.mjs test",
    "verify:app-templates": "node scripts/verify-app-templates.mjs",
    "lint": "pnpm lint:naming && pnpm lint:scripts && turbo lint && pnpm lint:style",
    "lint:naming": "node scripts/check-workspace-names.mjs",
    "lint:scripts": "eslint scripts",
    "lint:unused": "knip",
    "lint:style": "stylelint \"{apps,packages}/**/*.{css,scss,sass,vue}\"",
    "lint:style:fix": "pnpm lint:style --fix",
    "typecheck": "turbo typecheck",
    "test": "pnpm test:scripts && turbo test",
    "test:e2e": "turbo test:e2e",
    "test:e2e:all": "turbo test:e2e:all",
    "test:e2e:react": "pnpm --filter @apps/react-web test:e2e",
    "test:e2e:vue": "pnpm --filter @apps/vue-web test:e2e",
    "test:e2e:install": "playwright install chromium",
    "test:e2e:install:all": "playwright install chromium firefox webkit",
    "test:scripts": "vitest run scripts/generator scripts/version",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "clean": "turbo clean && pnpm clean:node-modules",
    "clean:node-modules": "node scripts/clean-node-modules.mjs",
    "prepare": "husky"
  },
  "devDependencies": {
    "@commitlint/cli": "^20.5.0",
    "@commitlint/config-conventional": "^20.5.0",
    "@playwright/test": "catalog:",
    "@repo/eslint-config": "workspace:*",
    "@types/node": "catalog:",
    "@vitest/coverage-v8": "catalog:",
    "cross-env": "catalog:",
    "eslint": "^9.39.1",
    "eslint-config-prettier": "^10.1.8",
    "fast-glob": "catalog:",
    "husky": "^9.1.7",
    "knip": "catalog:",
    "lint-staged": "^16.2.7",
    "postcss-html": "catalog:",
    "prettier": "^3.6.2",
    "rimraf": "^6.1.2",
    "stylelint": "catalog:",
    "stylelint-config-recommended-vue": "catalog:",
    "stylelint-config-standard": "catalog:",
    "stylelint-config-standard-scss": "catalog:",
    "turbo": "^2.6.1",
    "typescript": "catalog:",
    "validate-npm-package-name": "catalog:",
    "vite": "^8.1.0",
    "vitest": "catalog:",
    "yaml": "catalog:"
  },
  "pnpm": {
    "onlyBuiltDependencies": [
      "@prisma/engines",
      "prisma"
    ]
  }
}
